# Telegram (M&C bot + Izimoto bot)
# M&C bot receives new leads + quotes, and handles the "Called" button.
TELEGRAM_MC_BOT_TOKEN=
TELEGRAM_MC_CHAT_ID=
# Izimoto bot receives "Quote this lead" messages with a /q link.
TELEGRAM_IZI_BOT_TOKEN=
TELEGRAM_IZI_CHAT_ID=
# Optional: if you want /chatid@botname to work for Izimoto bot
TELEGRAM_IZI_BOT_USERNAME=
# Optional: webhook secret for Izimoto bot (if set, setWebhook uses secret_token)
TELEGRAM_IZI_WEBHOOK_SECRET=
# Webhook secret for the M&C bot (optional)
TELEGRAM_WEBHOOK_SECRET=
# Optional: protect /api/telegram/setup
TELEGRAM_SETUP_KEY=

# Used to sign /q/<leadId>?t=... links
LEAD_LINK_SECRET=

# Admin CRM auth
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Quoting / invoice
DEFAULT_COMMISSION_PERCENT=0

# Storage (pick one)
# Vercel KV
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: force the base URL used when generating /q/<leadId> links (otherwise uses VERCEL_URL/headers)
NEXT_PUBLIC_BASE_URL=https://matthews-clark-lead-flow.vercel.app

# Vercel Blob (needed for PDF uploads from /q/<leadId>)
BLOB_READ_WRITE_TOKEN=

# Neon Postgres (WhatsApp conversation storage — auto-populated by Vercel Marketplace)
DATABASE_URL=            # Pooler connection string (-pooler.neon.tech) — runtime queries
DATABASE_URL_UNPOOLED=   # Direct connection string — migrations only (npm run migrate)

# Meta WhatsApp Cloud API
WHATSAPP_APP_SECRET=        # App Secret — HMAC verification (NOT the access token)
WHATSAPP_VERIFY_TOKEN=      # Random string you choose; same value entered in Meta webhook setup
WHATSAPP_ACCESS_TOKEN=      # System User permanent token — Graph API + WABA subscribe
WHATSAPP_PHONE_NUMBER_ID=   # Phone Number ID from Meta (sending — Phase 11, declared now)
WHATSAPP_WABA_ID=           # WhatsApp Business Account ID — WABA subscription
