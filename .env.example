# Telegram (M&C bot + Izimoto bot)
# M&C bot receives new leads + quotes, and handles the "Called" button.
TELEGRAM_MC_BOT_TOKEN=
TELEGRAM_MC_CHAT_ID=
# Izimoto bot receives "Quote this lead" messages with a /q link.
TELEGRAM_IZI_BOT_TOKEN=
TELEGRAM_IZI_CHAT_ID=
# Optional: if you want /chatid@botname to work for Izimoto bot
TELEGRAM_IZI_BOT_USERNAME=
# Optional: webhook secret for Izimoto bot (if set, setWebhook uses secret_token)
TELEGRAM_IZI_WEBHOOK_SECRET=
# Webhook secret for the M&C bot (optional)
TELEGRAM_WEBHOOK_SECRET=
# Optional: protect /api/telegram/setup
TELEGRAM_SETUP_KEY=

# Used to sign /q/<leadId>?t=... links
LEAD_LINK_SECRET=

# Admin CRM auth
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Quoting / invoice
DEFAULT_COMMISSION_PERCENT=0

# Storage (pick one)
# Vercel KV
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: force the base URL used when generating /q/<leadId> links (otherwise uses VERCEL_URL/headers)
NEXT_PUBLIC_BASE_URL=https://matthews-clark-lead-flow.vercel.app

# Vercel Blob (needed for PDF uploads from /q/<leadId>)
BLOB_READ_WRITE_TOKEN=

# OpenAI (used by /api/wrap-render for GPT-Image-1 studio renders)
OPENAI_API_KEY=

# Remote CRM MCP endpoint (/api/mcp). When unset, the remote endpoint is
# disabled (returns 503). When set, every request must send
# `Authorization: Bearer <this value>`. Use a long random string.
MCP_BEARER_TOKEN=

# Ad pixels (public IDs — rendered into page source). A pixel is off until its
# id is set. Meta defaults to the live M/C pixel in code if unset.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Conversions API (server-side, SECRET — do not prefix NEXT_PUBLIC). Each
# platform's server events are off until its access token is set.
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional: Meta Events Manager "Test Events" code for verifying CAPI.
META_TEST_EVENT_CODE=
TIKTOK_PIXEL_ID=
TIKTOK_CAPI_ACCESS_TOKEN=

# ── Web Push notifications (Phase 10) ──────────────────────────────
# Generate a VAPID keypair ONCE and reuse it across ALL deployments.
# Changing these invalidates every existing push subscription.
#   node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys(),null,2))"
# Add the SAME public value to both VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# VAPID subject is a mailto: address (NOT https://localhost — Safari/iOS rejects it).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
